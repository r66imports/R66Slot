{
  "name": "r66-editor",
  "displayName": "R66 Editor",
  "description": "Visual editor with direct manipulation for R66 section layouts",
  "version": "1.0.0",
  "publisher": "r66slot",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "r66Editor.openEditor",
        "title": "R66: Open Visual Editor"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "r66Editor.openEditor",
          "when": "resourceExtname == .json || resourceExtname == .ts",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.x",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x"
  }
}
